# ===========================================
# Travel WhatsApp Bot - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# AI Provider Configuration
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
AI_PROVIDER=groq  # Options: groq, openai

# 360dialog WhatsApp BSP
DIALOG360_API_KEY=your_360dialog_api_key_here

# Database (PostgreSQL)
DATABASE_URL=postgres://travelbot:travelbot_secret@localhost:5432/travelbot

# Agency Configuration
AGENCY_NAME=Your Travel Agency Name
AGENCY_AGENT_NUMBER=+919876543210  # WhatsApp number for human handoff
AGENCY_FALLBACK_NUMBER=+919876543210  # Alternative contact number

# Business Hours (24-hour format, timezone from BUSINESS_TIMEZONE)
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=18:00
BUSINESS_TIMEZONE=Asia/Dubai  # Options: Asia/Dubai, Asia/Kolkata, etc.

# Application Settings
NODE_ENV=development
PORT=3000

# Session Configuration
SESSION_EXPIRY_HOURS=24
MAX_MESSAGES_PER_MINUTE=30