{
  "name": "travel-whatsapp-bot",
  "version": "1.0.0",
  "description": "WhatsApp AI Travel Assistant for travel agencies — Node.js + TypeScript, Groq LLM, 360dialog BSP",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "whatsapp",
    "travel",
    "chatbot",
    "ai",
    "groq",
    "360dialog"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "groq-sdk": "^0.5.0",
    "openai": "^4.52.7",
    "pg": "^8.12.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "vitest": "^1.6.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}